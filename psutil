def is_pe_file(path):
    try:
        with open(path, 'rb') as f:
            if f.read(2) != b'MZ':
                return False
            f.seek(0x3C)
            pe_offset = int.from_bytes(f.read(4), byteorder='little')
            f.seek(pe_offset)
            if f.read(4) != b'PE\x00\x00':
                return False
        return True
    except:
        return False

