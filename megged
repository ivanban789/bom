            else:
                hawk.warning(f"TESTING: Would have exited - RAM {gb:.2f} GB")
        hawk.info("[RAM_CHECK] pass")
    except Exception as e:
        hawk.critical(f"[RAM_CHECK] unexpected error: {e}", exc_info=True)
        if not TESTING_MODE:
