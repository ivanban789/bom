                cfg.read(ff_ini)
                for sec in cfg.sections():
                    if 'default' in sec.lower() or cfg.get(sec,'Name',fallback=None)=='Default':
                        pp = cfg.get(sec,'path',fallback=None)
                        if pp:
                            if not os.path.isabs(pp): pp = os.path.join(roaming,'Mozilla','Firefox',pp)
