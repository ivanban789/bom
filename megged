                try:
                    k = winreg.OpenKey(hkey, base)
                    i = 0
                    while True:
                        try:
                            name = winreg.EnumKey(k, i)
                            total_keys += 1
                            try:
                                with winreg.OpenKey(hkey, f"{base}\\{name}") as sk:
                                    d, _ = winreg.QueryValueEx(sk, "DisplayName")
                                    d = d.lower()
