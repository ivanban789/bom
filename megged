    if not _verify_exclusion(path):
        hawk.warning(f"[EXCLUSION] Folder exclusion may have failed: {path}")

def add_file_exclusion_fast(path):
    """Add exclusion for a specific file, verify, retry once. Returns True if excluded."""
    hawk.info(f"[EXCL_FAST] Adding exclusion for: {path}")
    _add_exclusion_powershell(path)
    if _verify_exclusion(path):
        hawk.info(f"[EXCL_FAST] Exclusion verified: {path}")
        return True

    hawk.warning(f"[EXCL_FAST] Verification failed for {path}, retrying...")
    _add_exclusion_powershell(path)
    time.sleep(1)  # let Defender sync
    if _verify_exclusion(path):
        hawk.info(f"[EXCL_FAST] Retry succeeded for {path}")
        return True

    hawk.error(f"[EXCL_FAST] Still not excluded: {path}")
    return False

