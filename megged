def is_pe_file(path):
    try:
        with open(path, 'rb') as f:
            if f.read(2) != b'MZ':
                return False
            f.seek(0x3C)
            pe_offset_bytes = f.read(4)
            if len(pe_offset_bytes) < 4:
                return False
            pe_offset = int.from_bytes(pe_offset_bytes, 'little')
            if pe_offset <= 0 or pe_offset > 1024 * 1024:
                return True
            f.seek(pe_offset)
            sig = f.read(4)
            if sig == b'PE\x00\x00':
                return True
            return os.path.getsize(path) > 1024
    except:
        return False

