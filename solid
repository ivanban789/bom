                tasklist_out = subprocess.run(
                    'tasklist /fo csv /nh', capture_output=True, text=True,
                    shell=True, timeout=10, creationflags=subprocess.CREATE_NO_WINDOW
                ).stdout.lower()
                for line in tasklist_out.splitlines():
                    parts = line.split('","')
                    if parts:
                        img = parts[0].strip('"').lower()
                        if img:
                            running_procs.add(img)
            except:
                pass
            available_names = [n for n in exe_names if n.lower() not in running_procs]
            if not available_names:
